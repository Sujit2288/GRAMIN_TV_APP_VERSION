private void handleStatus(String status, String telegram) {

    switch (NEW_VERSION_AVAILABLE) {

        case "UNDER_CONSTRUCTION":
            showUnderConstruction(telegram);
            break;

        case "SERVER_DOWN":
            showServerDown(telegram);
            break;

        case "NEW_VERSION_AVAILABLE":
            showUpdateRequired(https://www.mediafire.com/file/wg9qytx4n5zhe3b/com.gramintv.in_v1.apk);
            break;

        case "ACTIVE":
            handleActive();
            break;

        default:
            showServerDown(telegram);
            break;
    }
